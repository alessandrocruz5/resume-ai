generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model MasterResume {
  id              String           @id @default(cuid())
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  personalInfo    PersonalInfo?
  workExperiences WorkExperience[]
  skills          Skill[]
  education       Education[]
  projects        Project[]
}

model PersonalInfo {
  id             String       @id @default(cuid())
  name           String       @default("")
  email          String       @default("")
  phone          String?
  linkedin       String?
  location       String?
  masterResumeId String       @unique
  masterResume   MasterResume @relation(fields: [masterResumeId], references: [id], onDelete: Cascade)
}

model WorkExperience {
  id             String       @id @default(cuid())
  company        String
  title          String
  startDate      String
  endDate        String?
  bullets        String[]
  sortOrder      Int          @default(0)
  masterResumeId String
  masterResume   MasterResume @relation(fields: [masterResumeId], references: [id], onDelete: Cascade)
}

model Skill {
  id             String       @id @default(cuid())
  name           String
  category       String       @default("General")
  masterResumeId String
  masterResume   MasterResume @relation(fields: [masterResumeId], references: [id], onDelete: Cascade)
}

model Education {
  id             String       @id @default(cuid())
  school         String
  degree         String
  startDate      String?
  endDate        String?
  masterResumeId String
  masterResume   MasterResume @relation(fields: [masterResumeId], references: [id], onDelete: Cascade)
}

model Project {
  id             String       @id @default(cuid())
  name           String
  description    String?
  bullets        String[]
  url            String?
  sortOrder      Int          @default(0)
  masterResumeId String
  masterResume   MasterResume @relation(fields: [masterResumeId], references: [id], onDelete: Cascade)
}

model JobApplication {
  id                 String           @id @default(cuid())
  companyName        String
  jobTitle           String
  jobDescriptionText String
  companyContextText String?
  createdAt          DateTime         @default(now())
  tailoredResumes    TailoredResume[]
  coverLetters       CoverLetter[]
}

model TailoredResume {
  id               String         @id @default(cuid())
  jobApplicationId String
  createdAt        DateTime       @default(now())
  label            String?
  tailoredSections Json
  addedExperiences Json?
  atsScore         Int?
  atsKeywordReport Json?
  jobApplication   JobApplication @relation(fields: [jobApplicationId], references: [id], onDelete: Cascade)
}

model CoverLetter {
  id               String         @id @default(cuid())
  jobApplicationId String
  createdAt        DateTime       @default(now())
  content          String
  jobApplication   JobApplication @relation(fields: [jobApplicationId], references: [id], onDelete: Cascade)
}
